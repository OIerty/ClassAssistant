# ============================
# 上课摸鱼搭子 - 环境变量配置
# ============================

# FastAPI 后端端口
API_PORT=8765

# OpenAI Compatible API 配置
# 替换为你自己的 API 地址和密钥
# 当前仅保留示例值，请替换为你自己的 API 地址和密钥
LLM_BASE_URL=https://api.deepseek.com/
LLM_API_KEY=sk-your-api-key
LLM_MODEL=deepseek-chat

# ASR 模式: local / windows / winasr / mock / dashscope / seed-asr
# local: 免费语音识别（Google Speech API，无需密钥，需联网）
# windows: Windows 内置语音识别（WinRT SpeechRecognizer）
# winasr: 通过本地 C# WinRT 控制台程序调用微软原生 API
# mock: 空实现，仅测试 UI
ASR_MODE=local

# 转录策略
# 0: 保留完整课堂转录（默认）
# 1: 每 50 行滚动压缩为历史摘要，减少上下文体积
TRANSCRIPT_ENABLE_ROLLING_SUMMARY=0

# DashScope (阿里云百炼 Fun-ASR) 配置
DASHSCOPE_API_KEY=sk-your-dashscope-key
# DashScope ASR 模型名（可填 fun-asr-realtime / paraformer-realtime-v2 / 其他可用模型）
DASHSCOPE_ASR_MODEL=fun-asr-realtime

# Seed-ASR (字节跳动) 配置
SEED_ASR_WS_URL=wss://openspeech.bytedance.com/api/v3/sauc/bigmodel
SEED_ASR_APP_KEY=
SEED_ASR_ACCESS_KEY=
SEED_ASR_RESOURCE_ID=volc.bigasr.sauc.duration

# WinRT C# 桥接识别配置
# WINASR_LANGUAGE=zh-CN
# WINASR_EXE_PATH=D:\Dev\ClassAssistant\winasr\WinAsr.exe
# 识别参数调优：单位为秒，按需取消注释并调整
WINASR_INITIAL_SILENCE_SECONDS=8
WINASR_END_SILENCE_SECONDS=2.5
WINASR_BABBLE_SECONDS=8
WINASR_AUTO_STOP_SECONDS=3600
# 0.0-1.0，低于阈值的最终结果会被丢弃；留空则不启用
WINASR_CONFIDENCE_THRESHOLD=0.7

# 录音参数
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1
AUDIO_CHUNK_SIZE=1024
